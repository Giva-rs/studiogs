---
const stats = [
  { num: '60', suffix: '+', label: 'Projetos entregues' },
  { num: '4',  suffix: '+', label: 'Anos de experiência' },
  { num: '100', suffix: '%', label: 'Clientes satisfeitos' },
];
---

<section
  id="hero"
  class="relative overflow-hidden"
  style="min-height: 520px;"
>
  <!-- CAMADA 1 (fundo): imagem de background -->
  <div
    class="absolute inset-0 z-0"
    style="
      background-image: url('/studiogs/images/hero-bg.webp');
      background-size: cover;
      background-position: center 40%;
    "
  ></div>

  <!-- Overlay gradiente sobre a imagem -->
  <div
    class="absolute inset-0 z-[1]"
    style="background: linear-gradient(to right, rgba(13,27,42,0.93) 45%, rgba(13,27,42,0.65) 75%, rgba(13,27,42,0.4) 100%);"
  ></div>

  <!-- CAMADA 2 (meio): partículas com fundo transparente -->
  <div id="tsparticles" class="absolute inset-0 z-[2]"></div>

  <!-- CAMADA 3 (frente): conteúdo -->
  <div class="relative z-[3] px-10 pt-[90px] pb-20">
    <div class="max-w-2xl">

      <p class="font-sans text-[11px] tracking-[2px] uppercase text-gold mb-5 flex items-center gap-2.5">
        <span class="w-8 h-px bg-gold inline-block"></span>
        Agência de Desenvolvimento Web — Ribeirão Preto
      </p>

      <h1 class="font-serif text-[44px] font-bold text-white leading-[1.15] mb-5 tracking-tight">
        Criamos sites que <em class="not-italic text-gold-light">convertem</em> visitantes em clientes
      </h1>

      <p class="font-sans text-base text-white/65 leading-[1.7] max-w-[520px] mb-9">
        Desenvolvemos soluções digitais completas — de landing pages institucionais a e-commerces robustos — com foco em resultados mensuráveis para empresas.
      </p>

      <div class="flex gap-3.5 items-center flex-wrap">
        <a href="#projetos" class="btn-primary">Ver portfólio</a>
        <a href="#contato" class="btn-outline">Solicitar orçamento</a>
      </div>

      <div class="flex gap-12 mt-14 pt-10 border-t border-white/10 flex-wrap">
        {stats.map((s) => (
          <div>
            <p class="font-serif text-[32px] font-bold text-white leading-none">
              {s.num}<span class="text-gold">{s.suffix}</span>
            </p>
            <p class="font-sans text-[12px] text-white/50 mt-1 tracking-wide">{s.label}</p>
          </div>
        ))}
      </div>

    </div>
  </div>
</section>

<script defer src="https://cdn.jsdelivr.net/npm/tsparticles-slim@2.12.0/tsparticles.slim.bundle.min.js"></script>
<script>
  document.addEventListener('DOMContentLoaded', async () => {
    const waitForTsParticles = () => new Promise((resolve) => {
      if (typeof tsParticles !== 'undefined') return resolve(true);
      const interval = setInterval(() => {
        if (typeof tsParticles !== 'undefined') {
          clearInterval(interval);
          resolve(true);
        }
      }, 100);
    });
    await waitForTsParticles();
    await tsParticles.load("tsparticles", {
      fullScreen: { enable: false },
      background: { color: { value: "transparent" } },
      particles: {
        number: { value: 120, density: { enable: true, area: 800 } },
        color: { value: "#ffffff" },
        shape: { type: "circle" },
        opacity: {
          value: { min: 0, max: 0.5 },
          animation: { enable: true, speed: 1, sync: false }
        },
        size: {
          value: { min: 1, max: 2 },
          random: true
        },
        links: { enable: false },
        move: {
          enable: true,
          speed: 0.6,
          direction: "none",
          random: true,
          straight: false,
          outModes: { default: "out" }
        }
      },
      interactivity: {
        events: {
          onHover: { enable: true, mode: "bubble" },
          onClick: { enable: true, mode: "repulse" },
          resize: true
        },
        modes: {
          bubble: { distance: 200, size: 0, duration: 2, opacity: 0 },
          repulse: { distance: 300, duration: 0.4 }
        }
      },
      detectRetina: true
    });
  });
</script>
