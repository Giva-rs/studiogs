---
const projects = [
  {
    imgSrc: '/studiogs/images/projeto-femgi-lg.webp',
    imgSrcset: '/studiogs/images/projeto-femgi-sm.webp 600w, /studiogs/images/projeto-femgi-md.webp 900w, /studiogs/images/projeto-femgi-lg.webp 1280w',
    imgAlt: 'Site FEMGI — Projetos que conectam ideias',
    type: 'Institucional',
    title: 'FEMGI',
    description: 'Site institucional moderno com foco em clareza, estética contemporânea e captação de projetos arquitetônicos, reformas e gestão de obras.',
    tech: 'HTML · JS · CSS · SEO',
    url: 'https://www.femgi.com.br',
  },
  {
    imgSrc: '/studiogs/images/projeto-lojatudolar-lg.webp',
    imgSrcset: '/studiogs/images/projeto-lojatudolar-sm.webp 600w, /studiogs/images/projeto-lojatudolar-md.webp 900w, /studiogs/images/projeto-lojatudolar-lg.webp 1280w',
    imgAlt: 'E-commerce Tudolar — Artigos para o lar e muito mais',
    type: 'E-commerce',
    title: 'Loja Tudolar',
    description: 'E-commerce completo com catálogo de produtos, categorias, barra de busca, checkout transparente e integração com WhatsApp para atendimento.',
    tech: 'Yampi · PHP · WhatsApp',
    url: 'https://www.lojatudolar.com.br',
  },
  {
    imgSrc: '/studiogs/images/projeto-thairine-lg.webp',
    imgSrcset: '/studiogs/images/projeto-thairine-sm.webp 600w, /studiogs/images/projeto-thairine-md.webp 900w, /studiogs/images/projeto-thairine-lg.webp 1280w',
    imgAlt: 'Site Thairine Pacheco — Atendimento Nutricional Online',
    type: 'Landing Page',
    title: 'Thairine Pacheco Nutricionista',
    description: 'Landing page para nutricionista com agendamento via WhatsApp, apresentação de serviços e depoimentos de pacientes.',
    tech: 'WIX · Google Reviews · Forms',
    url: 'https://www.thairinenutricionista.com/thairine-pacheco-nutricionista-online-consulta-nutricional-online',
  },
  {
    imgSrc: '/studiogs/images/projeto-upbarber-lg.webp',
    imgSrcset: '/studiogs/images/projeto-upbarber-sm.webp 600w, /studiogs/images/projeto-upbarber-md.webp 900w, /studiogs/images/projeto-upbarber-lg.webp 1280w',
    imgAlt: 'Site Up Barber — Sua melhor versão começa aqui',
    type: 'Institucional',
    title: 'Up Barber',
    description: 'Site para barbearia com galeria de serviços, agendamento online via WhatsApp e localização integrada ao Google Maps.',
    tech: 'WordPress · Elementor · Google Maps',
    url: 'https://giva-rs.github.io/UPbarber/',
  },
];
---
<section id="projetos" class="px-10 py-[72px]">
  <p class="section-tag">Cases</p>
  <h2 class="section-title">Projetos selecionados</h2>
  <p class="section-sub">
    Uma amostra breve do nosso trabalho para empresas de diferentes segmentos.
  </p>
  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
  {projects.map((p, i) => (
    <article class="border border-[#E8ECF2] rounded-[6px] overflow-hidden bg-white group">
      <div class="w-full overflow-hidden" style="aspect-ratio: 19/9;">
        <img
          src={p.imgSrc}
          srcset={p.imgSrcset}
          sizes="(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 640px"
          alt={p.imgAlt}
          width="1280"
          height="603"
          class="w-full h-full object-cover object-center transition-transform duration-500 group-hover:scale-105"
          loading={i === 0 ? 'eager' : 'lazy'}
          fetchpriority={i === 0 ? 'high' : 'auto'}
        />
      </div>
        <!-- Conteúdo -->
        <div class="p-5">
          <p class="font-sans text-[11px] font-bold tracking-[1.5px] uppercase text-blue-accent mb-1.5">
            {p.type}
          </p>
          <h3 class="font-sans text-base font-bold text-navy mb-2">{p.title}</h3>
          <p class="font-sans text-[13px] text-[#5A6A7E] leading-[1.6]">{p.description}</p>
          <div class="flex items-center justify-between mt-3.5 pt-3.5 border-t border-[#E8ECF2]">
            <span class="font-sans text-[11px] text-[#9AA3B0]">{p.tech}</span>
            <a href={p.url} class="font-sans text-[12px] font-bold text-blue-accent no-underline hover:underline">
              Visitar site →
            </a>
          </div>
        </div>
      </article>
    ))}
  </div>
</section>
