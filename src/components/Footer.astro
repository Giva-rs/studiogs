---
const year = new Date().getFullYear();
const socialLinks = [
  { label: 'LinkedIn', href: 'https://www.linkedin.com/in/givaldo-ti' },
  { label: 'GitHub', href: 'https://github.com/giva-rs' },
  { label: 'Instagram', href: 'https://www.instagram.com/givaldo.rs/' },
];
---

<footer class="bg-navy px-10 py-6 flex flex-col md:flex-row items-center justify-between gap-4">
  <p class="font-sans text-[12px] text-white/35">
    © {year} StudioGS. Todos os direitos reservados.
  </p>
  <div class="flex gap-5">
    {socialLinks.map((link) => (
      <a
        href={link.href}
        target="_blank"
        rel="noopener noreferrer"
        class="font-sans text-[12px] text-white/100 no-underline hover:text-white/100 transition-colors"
      >
        {link.label}
      </a>
    ))}
  </div>
</footer>
